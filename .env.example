# MongoDB
MONGODB_URI=

# 관리자 (평문 비밀번호·시크릿은 저장소에 넣지 마세요)
ADMIN_PASSWORD=
ADMIN_SECRET=

# Cloudflare R2 (이미지 업로드) — docs/cloudflare-r2.md 참고
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# 공개 URL (R2.dev 커스텀 도메인 또는 퍼블릭 베이스, 끝에 / 없이)
R2_PUBLIC_BASE_URL=

# Gmail SMTP (Contact 폼)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=

# Naver Map (Studio 지도)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# Site URL (SEO / OG 메타태그)
NEXT_PUBLIC_SITE_URL=